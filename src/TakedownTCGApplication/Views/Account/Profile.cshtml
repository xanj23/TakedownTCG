@model ProfileViewModel
@{
    ViewData["Title"] = "Account Profile";
}

<section class="space-y-4">
    <div class="rounded-3xl border border-slate-300 bg-white/90 p-6 shadow-sm md:p-8">
        <h1 class="text-3xl font-extrabold text-slate-900">Account Profile</h1>
        <div class="mt-4 grid gap-3 text-sm text-slate-700 md:grid-cols-3">
            <div class="rounded-xl bg-slate-100 p-3"><span class="font-semibold">Username:</span> @Model.UserName</div>
            <div class="rounded-xl bg-slate-100 p-3"><span class="font-semibold">Email:</span> @Model.Email</div>
            <div class="rounded-xl bg-slate-100 p-3"><span class="font-semibold">Notifications:</span> @(Model.NotificationsEnabled ? "Enabled" : "Disabled")</div>
        </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        <form asp-action="ChangeUserName" method="post" class="panel-card space-y-3">
            @Html.AntiForgeryToken()
            <h2 class="text-xl font-bold text-slate-900">Change Username</h2>
            <input name="NewUserName" class="form-input" placeholder="New username" />
            <button type="submit" class="btn-primary">Update Username</button>
        </form>

        <form asp-action="ChangeEmail" method="post" class="panel-card space-y-3">
            @Html.AntiForgeryToken()
            <h2 class="text-xl font-bold text-slate-900">Change Email</h2>
            <input name="NewEmail" class="form-input" type="email" placeholder="New email" />
            <button type="submit" class="btn-primary">Update Email</button>
        </form>

        <form asp-action="ChangePassword" method="post" class="panel-card space-y-3">
            @Html.AntiForgeryToken()
            <h2 class="text-xl font-bold text-slate-900">Change Password</h2>
            <input name="CurrentPassword" class="form-input" type="password" placeholder="Current password" />
            <input name="NewPassword" class="form-input" type="password" placeholder="New password" />
            <button type="submit" class="btn-primary">Update Password</button>
        </form>

        <div class="panel-card space-y-3">
            <h2 class="text-xl font-bold text-slate-900">Notifications</h2>
            <p class="text-sm text-slate-600">Toggle account notifications in one click.</p>
            <form asp-action="ToggleNotifications" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-ghost">Toggle Notifications</button>
            </form>
        </div>
    </div>

    <form asp-action="DeleteAccount" method="post" class="rounded-2xl border border-rose-300 bg-rose-50 p-5">
        @Html.AntiForgeryToken()
        <h2 class="text-xl font-bold text-rose-900">Delete Account</h2>
        <p class="mt-1 text-sm text-rose-700">Type <strong>DELETE</strong> to permanently remove your account.</p>
        <div class="mt-3 flex flex-col gap-2 sm:flex-row">
            <input name="Confirmation" class="form-input border-rose-300" placeholder="DELETE" />
            <button type="submit" class="rounded-xl bg-rose-700 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-800">Delete Account</button>
        </div>
    </form>
</section>
