@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="mx-auto max-w-xl rounded-3xl border border-slate-300 bg-white/90 p-6 shadow-sm md:p-8">
    <h1 class="text-3xl font-extrabold text-slate-900">Sign In</h1>
    <p class="mt-2 text-sm text-slate-600">Access your account and continue building your favorites list.</p>

    <form asp-action="Login" method="post" class="mt-6 space-y-4">
        @Html.AntiForgeryToken()
        <input asp-for="ReturnUrl" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="rounded-lg bg-rose-50 p-2 text-sm text-rose-700"></div>

        <label class="block">
            <span class="form-label">Username or Email</span>
            <input asp-for="UserNameOrEmail" class="form-input" />
            <span asp-validation-for="UserNameOrEmail" class="form-error"></span>
        </label>

        <label class="block">
            <span class="form-label">Password</span>
            <input asp-for="Password" class="form-input" />
            <span asp-validation-for="Password" class="form-error"></span>
        </label>

        <button type="submit" class="btn-primary w-full">Login</button>
    </form>

    <p class="mt-4 text-sm text-slate-600">Need an account? <a asp-action="Register" class="font-semibold text-cyan-700">Create one</a>.</p>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
