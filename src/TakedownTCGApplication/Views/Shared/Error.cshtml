@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="rounded-2xl border border-rose-300 bg-rose-50 p-6 text-rose-900">
    <h1 class="text-2xl font-extrabold">Something went wrong.</h1>
    <p class="mt-2 text-sm">An error occurred while processing your request.</p>
    @if (Model.ShowRequestId)
    {
        <p class="mt-2 text-xs">Request ID: <code>@Model.RequestId</code></p>
    }
</section>
