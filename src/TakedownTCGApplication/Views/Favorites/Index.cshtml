@model FavoritesIndexViewModel
@{
    ViewData["Title"] = "Favorites";
}

<section class="space-y-5">
    <div class="rounded-3xl border border-slate-300 bg-white/90 p-6 shadow-sm">
        <h1 class="text-3xl font-extrabold text-slate-900">Favorites for @Model.UserName</h1>
        <p class="mt-1 text-sm text-slate-600">Your saved cards, sets, and games.</p>
    </div>

    @if (Model.Favorites.Count == 0)
    {
        <div class="rounded-xl border border-slate-300 bg-white/80 p-4 text-sm text-slate-600">No favorites yet.</div>
    }
    else
    {
        <div class="grid gap-3 md:grid-cols-2">
            @foreach (var favorite in Model.Favorites)
            {
                <article class="panel-card">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-wide text-cyan-700">@favorite.ItemType</p>
                            <h2 class="text-lg font-bold text-slate-900">@favorite.ItemName</h2>
                            <p class="text-xs text-slate-500">Id: @favorite.ItemId</p>
                            <p class="mt-1 text-xs text-slate-500">Added: @favorite.CreatedAt.ToString("u")</p>
                        </div>
                        <form asp-action="Remove" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="itemType" value="@favorite.ItemType" />
                            <input type="hidden" name="itemId" value="@favorite.ItemId" />
                            <button type="submit" class="rounded-lg bg-rose-700 px-3 py-2 text-xs font-semibold text-white hover:bg-rose-800">Remove</button>
                        </form>
                    </div>
                </article>
            }
        </div>
    }
</section>
