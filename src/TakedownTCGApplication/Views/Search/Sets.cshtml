@model SetsSearchViewModel
@{
    ViewData["Title"] = "Search Sets";
}

<section class="space-y-5">
    <div class="rounded-3xl border border-slate-300 bg-white/90 p-6 shadow-sm">
        <h1 class="text-3xl font-extrabold text-slate-900">Search Sets</h1>
        <p class="mt-1 text-sm text-slate-600">Required: game. Optional: query, order by, sort order.</p>

        <form asp-action="Sets" method="post" class="mt-4 grid gap-3 md:grid-cols-2">
            @Html.AntiForgeryToken()
            <label class="block">
                <span class="form-label">Game</span>
                <input asp-for="Game" class="form-input" placeholder="mtg, pokemon" />
                <span asp-validation-for="Game" class="form-error"></span>
            </label>
            <label class="block">
                <span class="form-label">Search Query</span>
                <input asp-for="Query" class="form-input" />
            </label>
            <label class="block">
                <span class="form-label">Order By</span>
                <input asp-for="OrderBy" class="form-input" placeholder="name or release_date" />
            </label>
            <label class="block">
                <span class="form-label">Sort Order</span>
                <input asp-for="Order" class="form-input" placeholder="asc or desc" />
            </label>
            <div class="md:col-span-2">
                <button type="submit" class="btn-primary">Run Set Search</button>
            </div>
        </form>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-xl border border-rose-300 bg-rose-50 p-3 text-sm text-rose-700">@Model.ErrorMessage</div>
    }

    @if (Model.Results.Count > 0)
    {
        <div class="grid gap-3 md:grid-cols-2">
            @foreach (var setItem in Model.Results)
            {
                <article class="panel-card">
                    <h3 class="text-lg font-bold text-slate-900">@setItem.Name</h3>
                    <p class="text-sm text-slate-600">@setItem.Game • Release: @setItem.ReleaseDate</p>
                    <div class="mt-2 grid grid-cols-2 gap-2 text-sm text-slate-700">
                        <span>Cards: @setItem.CardsCount</span>
                        <span>Variants: @setItem.VariantsCount</span>
                        <span>Sealed: @setItem.SealedCount</span>
                        <span>Value: $@setItem.SetValueUsd</span>
                    </div>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Favorites" asp-action="Add" method="post" class="mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ItemType" value="Set" />
                            <input type="hidden" name="ItemId" value="@setItem.Id" />
                            <input type="hidden" name="ItemName" value="@setItem.Name" />
                            <input type="hidden" name="ReturnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn-ghost">Add to Favorites</button>
                        </form>
                    }
                </article>
            }
        </div>
    }
    else
    {
        <div class="rounded-xl border border-slate-300 bg-white/80 p-4 text-sm text-slate-600">No set results yet.</div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
