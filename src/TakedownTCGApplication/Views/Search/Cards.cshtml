@model CardsSearchViewModel
@{
    ViewData["Title"] = "Search Cards";
}

<section class="space-y-5">
    <div class="rounded-3xl border border-slate-300 bg-white/90 p-6 shadow-sm">
        <h1 class="text-3xl font-extrabold text-slate-900">Search Cards</h1>
        <p class="mt-1 text-sm text-slate-600">Required: name. Optional: number, printing, condition.</p>

        <form asp-action="Cards" method="post" class="mt-4 grid gap-3 md:grid-cols-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Offset" value="0" />
            <input asp-for="Limit" type="hidden" />
            <label class="block md:col-span-2">
                <span class="form-label">Name</span>
                <input asp-for="Query" class="form-input" />
                <span asp-validation-for="Query" class="form-error"></span>
            </label>
            <label class="block">
                <span class="form-label">Card Number</span>
                <input asp-for="Number" class="form-input" />
            </label>
            <label class="block">
                <span class="form-label">Printing</span>
                <input asp-for="Printing" class="form-input" />
            </label>
            <label class="block">
                <span class="form-label">Condition</span>
                <input asp-for="Condition" class="form-input" />
            </label>
            <div class="md:col-span-2">
                <button type="submit" class="btn-primary">Run Card Search</button>
            </div>
        </form>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-xl border border-rose-300 bg-rose-50 p-3 text-sm text-rose-700">@Model.ErrorMessage</div>
    }

    @if (Model.Results.Count > 0)
    {
        <div class="grid gap-3 md:grid-cols-2">
            @foreach (var card in Model.Results)
            {
                var fallbackImageUrl = "https://tcgplayer-cdn.tcgplayer.com/product/image-missing.svg";
                var imageUrl = !string.IsNullOrWhiteSpace(card.TcgplayerId)
                    ? $"https://tcgplayer-cdn.tcgplayer.com/product/{card.TcgplayerId}_in_1000x1000.jpg"
                    : fallbackImageUrl;
                var displayPrice = card.Variants.Where(v => v.Price.HasValue).Select(v => v.Price).FirstOrDefault();

                <article class="panel-card">
                    <div class="flex items-start gap-4">
                        <img src="@imageUrl" alt="@card.Name" class="h-auto w-full rounded-xl border border-slate-200 bg-slate-50 object-contain" style="max-width: 10rem;" loading="lazy" onerror="this.onerror=null;this.src='@fallbackImageUrl';" />
                        <div class="flex-1">
                            <h3 class="text-lg font-bold text-slate-900">@card.Name</h3>
                            <p class="text-sm text-slate-600">@card.Game • @card.SetName (@card.Set) • #@card.Number</p>
                            <p class="mt-2 text-sm text-slate-700">Rarity: @card.Rarity</p>
                            @if (displayPrice.HasValue)
                            {
                                <p class="mt-1 text-sm font-semibold text-cyan-700">Price: $@displayPrice.Value.ToString("0.00")</p>
                            }
                            else
                            {
                                <p class="mt-1 text-sm font-semibold text-slate-500">Price: N/A</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(card.TcgplayerId))
                            {
                                var tcgplayerProductUrl = $"https://www.tcgplayer.com/product/{card.TcgplayerId}";
                                <p class="mt-1 text-xs">
                                    <a href="@tcgplayerProductUrl" target="_blank" rel="noopener noreferrer" class="text-cyan-700 underline">Price from TCGplayer</a>
                                </p>
                            }
                            @if (!string.IsNullOrWhiteSpace(card.Details))
                            {
                                <p class="mt-2 text-sm text-slate-600">@card.Details</p>
                            }
                            <div class="mt-3 text-xs text-slate-500">Variants: @card.Variants.Count</div>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-controller="Favorites" asp-action="Add" method="post" class="mt-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ItemType" value="Card" />
                                    <input type="hidden" name="ItemId" value="@card.Id" />
                                    <input type="hidden" name="ItemName" value="@card.Name" />
                                    <input type="hidden" name="ReturnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button type="submit" class="btn-ghost">Add to Favorites</button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>

        <div class="mt-4 flex items-center justify-center gap-3">
            @if (Model.HasPrevious)
            {
                <form asp-action="Cards" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Query" value="@Model.Query" />
                    <input type="hidden" name="Number" value="@Model.Number" />
                    <input type="hidden" name="Printing" value="@Model.Printing" />
                    <input type="hidden" name="Condition" value="@Model.Condition" />
                    <input type="hidden" name="Offset" value="@Model.PreviousOffset" />
                    <input type="hidden" name="Limit" value="@Model.Limit" />
                    <button type="submit" class="btn-ghost">Previous Page</button>
                </form>
            }

            <span class="text-sm font-semibold text-slate-700">Page @Model.CurrentPage of @Model.TotalPages</span>

            @if (Model.HasMore)
            {
                <form asp-action="Cards" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Query" value="@Model.Query" />
                    <input type="hidden" name="Number" value="@Model.Number" />
                    <input type="hidden" name="Printing" value="@Model.Printing" />
                    <input type="hidden" name="Condition" value="@Model.Condition" />
                    <input type="hidden" name="Offset" value="@Model.NextOffset" />
                    <input type="hidden" name="Limit" value="@Model.Limit" />
                    <button type="submit" class="btn-primary">Next Page</button>
                </form>
            }
        </div>
    }
    else
    {
        <div class="rounded-xl border border-slate-300 bg-white/80 p-4 text-sm text-slate-600">No card results yet.</div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
