@model GamesSearchViewModel
@{
    ViewData["Title"] = "Browse Games";
}

<section class="space-y-5">
    <div class="rounded-3xl border border-slate-300 bg-white/90 p-6 shadow-sm">
        <h1 class="text-3xl font-extrabold text-slate-900">Browse Games</h1>
        <p class="mt-1 text-sm text-slate-600">Fetch the full games endpoint from JustTCG.</p>

        <form asp-action="Games" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-primary">Load Games</button>
        </form>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-xl border border-rose-300 bg-rose-50 p-3 text-sm text-rose-700">@Model.ErrorMessage</div>
    }

    @if (Model.Results.Count > 0)
    {
        <div class="grid gap-3 md:grid-cols-2">
            @foreach (var game in Model.Results)
            {
                <article class="panel-card">
                    <h3 class="text-lg font-bold text-slate-900">@game.Name</h3>
                    <div class="mt-2 grid grid-cols-2 gap-2 text-sm text-slate-700">
                        <span>Sets: @game.SetsCount</span>
                        <span>Cards: @game.CardsCount</span>
                        <span>Variants: @game.VariantsCount</span>
                        <span>Sealed: @game.SealedCount</span>
                    </div>
                    <p class="mt-2 text-xs text-slate-500">Game Value Index (cents): @game.GameValueIndexCents</p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Favorites" asp-action="Add" method="post" class="mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ItemType" value="Game" />
                            <input type="hidden" name="ItemId" value="@game.Id" />
                            <input type="hidden" name="ItemName" value="@game.Name" />
                            <input type="hidden" name="ReturnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn-ghost">Add to Favorites</button>
                        </form>
                    }
                </article>
            }
        </div>
    }
    else
    {
        <div class="rounded-xl border border-slate-300 bg-white/80 p-4 text-sm text-slate-600">No game results yet.</div>
    }
</section>
