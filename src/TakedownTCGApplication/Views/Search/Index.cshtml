@model ProductsSearchViewModel
@{
    ViewData["Title"] = "Search Products";
    string endpoint = (Model.Endpoint ?? string.Empty).ToLowerInvariant();
    bool showCards = endpoint == "cards";
    bool showSets = endpoint == "sets";
    bool showGames = endpoint == "games";
}

<section class="space-y-5">
    <div class="rounded-3xl border border-slate-300 bg-white/90 p-6 shadow-sm">
        <h1 class="text-3xl font-extrabold text-slate-900">Search Products</h1>
        <p class="mt-1 text-sm text-slate-600">Choose an API, then matching fields will appear.</p>

        <form asp-action="Index" method="post" class="mt-4 grid gap-3 md:grid-cols-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Offset" value="0" />
            <input asp-for="Limit" type="hidden" />

            <label class="block">
                <span class="form-label">API</span>
                <select asp-for="Api" id="apiSelect" class="form-input">
                    @foreach (var apiOption in Model.ApiOptions)
                    {
                        <option value="@apiOption.Value"
                                data-endpoint-label="@apiOption.EndpointLabel"
                                data-default-endpoint="@apiOption.DefaultEndpoint"
                                data-requires-endpoint="@apiOption.RequiresEndpointSelection.ToString().ToLowerInvariant()">
                            @apiOption.Label
                        </option>
                    }
                </select>
                <span asp-validation-for="Api" class="form-error"></span>
            </label>

            <label id="endpointField" class="block">
                <span id="endpointLabel" class="form-label">Endpoint</span>
                <select asp-for="Endpoint" id="endpointSelect" class="form-input">
                    @foreach (var endpointOption in Model.EndpointOptions)
                    {
                        <option value="@endpointOption.Value"
                                data-apis="@endpointOption.SupportedApis"
                                data-category-ids="@endpointOption.CategoryIds">
                            @endpointOption.Label
                        </option>
                    }
                </select>
                <span asp-validation-for="Endpoint" class="form-error"></span>
            </label>

            <div data-search-fields data-api="JustTCG" data-endpoint="cards" class="hidden md:col-span-2 grid gap-3 md:grid-cols-2">
                <label class="block md:col-span-2">
                    <span class="form-label">Card Name</span>
                    <input asp-for="CardQuery" class="form-input" />
                    <span asp-validation-for="CardQuery" class="form-error"></span>
                </label>
                <label class="block">
                    <span class="form-label">Card Number</span>
                    <input asp-for="CardNumber" class="form-input" />
                </label>
                <label class="block">
                    <span class="form-label">Printing</span>
                    <input asp-for="CardPrinting" class="form-input" />
                </label>
                <label class="block">
                    <span class="form-label">Condition / Rarity</span>
                    <input asp-for="CardCondition" class="form-input" />
                </label>
                <label class="block">
                    <span class="form-label">Order By</span>
                    <select asp-for="CardOrderBy" class="form-input">
                        <option value="">Default</option>
                        <option value="relevance">relevance</option>
                        <option value="price">price</option>
                        <option value="24h">24h</option>
                        <option value="7d">7d</option>
                        <option value="30d">30d</option>
                    </select>
                </label>
                <label class="block">
                    <span class="form-label">Sort Order</span>
                    <select asp-for="CardOrder" class="form-input">
                        <option value="">Default</option>
                        <option value="asc">asc</option>
                        <option value="desc">desc</option>
                    </select>
                </label>
            </div>

            <div data-search-fields data-api="PokemonTCG" data-endpoint="cards" class="hidden md:col-span-2 grid gap-3 md:grid-cols-2">
                <label class="block md:col-span-2">
                    <span class="form-label">Pokemon Search</span>
                    <input asp-for="PokemonSearch" class="form-input" placeholder="charizard ex 199" />
                    <span asp-validation-for="PokemonSearch" class="form-error"></span>
                </label>
                <label class="block">
                    <span class="form-label">Pokemon TCG ID</span>
                    <input asp-for="PokemonTcgId" class="form-input" placeholder="sv3-223" />
                </label>
                <label class="block">
                    <span class="form-label">Sort</span>
                    <select asp-for="PokemonSort" class="form-input">
                        <option value="price_highest">price_highest</option>
                        <option value="price_lowest">price_lowest</option>
                        <option value="relevance">relevance</option>
                    </select>
                </label>
            </div>

            <div data-search-fields data-api="eBay" data-endpoint="cards" class="hidden md:col-span-2 grid gap-3 md:grid-cols-2">
                <input asp-for="EbayCategoryIds" type="hidden" id="ebayCategoryIds" />
                <label class="block md:col-span-2">
                    <span class="form-label">eBay Search</span>
                    <input asp-for="EbaySearch" class="form-input" placeholder="pokemon charizard psa 10" />
                    <span asp-validation-for="EbaySearch" class="form-error"></span>
                </label>
                <label class="block">
                    <span class="form-label">Buying Format</span>
                    <select asp-for="EbayBuyingOptions" class="form-input">
                        <option value="">Default</option>
                        <option value="FIXED_PRICE">Buy It Now</option>
                        <option value="AUCTION">Auction</option>
                        <option value="FIXED_PRICE|AUCTION">Buy It Now or Auction</option>
                    </select>
                </label>
                <label class="block">
                    <span class="form-label">Sort</span>
                    <select asp-for="EbaySort" class="form-input">
                        <option value="relevance">Best Match</option>
                        <option value="newlyListed">Newly Listed</option>
                        <option value="endingSoonest">Ending Soonest</option>
                        <option value="price">Price Low to High</option>
                        <option value="-price">Price High to Low</option>
                    </select>
                </label>
            </div>

            <div data-search-fields data-api="JustTCG" data-endpoint="sets" class="hidden md:col-span-2 grid gap-3 md:grid-cols-2">
                <label class="block">
                    <span class="form-label">Game</span>
                    <input asp-for="SetGame" class="form-input" placeholder="mtg, pokemon" />
                    <span asp-validation-for="SetGame" class="form-error"></span>
                </label>
                <label class="block">
                    <span class="form-label">Set Name</span>
                    <input asp-for="SetQuery" class="form-input" />
                </label>
                <label class="block">
                    <span class="form-label">Order By</span>
                    <select asp-for="SetOrderBy" class="form-input">
                        <option value="">Default</option>
                        <option value="name">name</option>
                        <option value="release_date">release_date</option>
                    </select>
                </label>
                <label class="block">
                    <span class="form-label">Sort Order</span>
                    <select asp-for="SetOrder" class="form-input">
                        <option value="">Default</option>
                        <option value="asc">asc</option>
                        <option value="desc">desc</option>
                    </select>
                </label>
            </div>

            <div class="md:col-span-2">
                <button type="submit" class="btn-primary">Run Search</button>
            </div>
        </form>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-xl border border-rose-300 bg-rose-50 p-3 text-sm text-rose-700">@Model.ErrorMessage</div>
    }

    @if (showCards && Model.CardDisplayResults.Count > 0)
    {
        <div class="grid gap-3 md:grid-cols-2">
            @foreach (var card in Model.CardDisplayResults)
            {
                <article class="panel-card">
                    <div class="flex items-start gap-4">
                        <img src="@card.ImageUrl" alt="@card.Name" class="h-auto w-full rounded-xl border border-slate-200 bg-slate-50 object-contain" style="max-width: 10rem;" loading="lazy" onerror="this.onerror=null;this.src='@card.FallbackImageUrl';" />
                        <div class="flex-1">
                            <h3 class="text-lg font-bold text-slate-900">@card.Name</h3>
                            <p class="text-sm text-slate-600">@card.Game | @card.SetName (@card.SetCode) | #@card.Number</p>
                            <p class="mt-2 text-sm text-slate-700">Rarity: @card.Rarity</p>
                            @if (card.DisplayPrice.HasValue)
                            {
                                <p class="mt-1 text-sm font-semibold text-cyan-700">
                                    @card.DisplayPriceLabel: $@card.DisplayPrice.Value.ToString("0.00")
                                    @if (card.Price90d.HasValue)
                                    {
                                        <span class="text-slate-600"> | Price was: $@card.Price90d.Value.ToString("0.00") 3 months ago</span>
                                    }
                                </p>
                            }
                            else
                            {
                                <p class="mt-1 text-sm font-semibold text-slate-500">Price: N/A</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(card.TcgplayerProductUrl))
                            {
                                <p class="mt-1 text-xs">
                                    <a href="@card.TcgplayerProductUrl" target="_blank" rel="noopener noreferrer" class="text-cyan-700 underline">@(card.Game == "eBay" ? "View listing on eBay" : "Price from TCGplayer")</a>
                                </p>
                            }
                            @if (!string.IsNullOrWhiteSpace(card.Details))
                            {
                                <p class="mt-2 text-sm text-slate-600">@card.Details</p>
                            }
                            <div class="mt-3">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <form asp-controller="Favorites"
                                          asp-action="Add"
                                          method="post"
                                          class="inline-flex js-favorite-form"
                                          data-remove-url="@Url.Action("Remove", "Favorites")">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ItemType" value="card" />
                                        <input type="hidden" name="ItemId" value="@card.Id" />
                                        <input type="hidden" name="ItemName" value="@card.Name" />
                                        <input type="hidden" name="ReturnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                                        <button type="submit"
                                                class="js-favorite-btn @(card.IsFavorited ? "btn-ghost bg-rose-50 text-rose-700 border border-rose-300" : "btn-ghost")"
                                                data-favorited="@(card.IsFavorited ? "true" : "false")"
                                                title="@(card.IsFavorited ? "Remove from favorites" : "Add to favorites")"
                                                aria-label="@(card.IsFavorited ? $"Remove {card.Name} from favorites" : $"Add {card.Name} to favorites")">
                                            &#9829; Favorite
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <a asp-controller="Account"
                                       asp-action="Login"
                                       asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                                       class="btn-ghost"
                                       title="Log in to add favorites">
                                        &#9829; Favorite
                                    </a>
                                }
                            </div>
                            <div class="mt-3 text-xs text-slate-500">Variants: @card.VariantsCount</div>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
    else if (showSets && Model.SetDisplayResults.Count > 0)
    {
        <div class="grid gap-3 md:grid-cols-2">
            @foreach (var setItem in Model.SetDisplayResults)
            {
                <article class="panel-card">
                    <h3 class="text-lg font-bold text-slate-900">@setItem.Name</h3>
                    <p class="text-sm text-slate-600">@setItem.Game | Release: @setItem.ReleaseDate</p>
                    <div class="mt-2 grid grid-cols-2 gap-2 text-sm text-slate-700">
                        <span>Cards: @setItem.CardsCount</span>
                        <span>Variants: @setItem.VariantsCount</span>
                        <span>Sealed: @setItem.SealedCount</span>
                        <span>Value: $@setItem.SetValueUsd</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(setItem.TcgplayerSetUrl))
                    {
                        <p class="mt-3 text-xs">
                            <a href="@setItem.TcgplayerSetUrl" target="_blank" rel="noopener noreferrer" class="text-cyan-700 underline">View set on TCGplayer</a>
                        </p>
                    }
                </article>
            }
        </div>
    }
    else if (showGames && Model.GameDisplayResults.Count > 0)
    {
        <div class="grid gap-3 md:grid-cols-2">
            @foreach (var game in Model.GameDisplayResults)
            {
                <article class="panel-card">
                    <h3 class="text-lg font-bold text-slate-900">@game.Name</h3>
                    <div class="mt-2 grid grid-cols-2 gap-2 text-sm text-slate-700">
                        <span>Sets: @game.SetsCount</span>
                        <span>Cards: @game.CardsCount</span>
                        <span>Variants: @game.VariantsCount</span>
                        <span>Sealed: @game.SealedCount</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(game.TcgplayerGameUrl))
                    {
                        <p class="mt-3 text-xs">
                            <a href="@game.TcgplayerGameUrl" target="_blank" rel="noopener noreferrer" class="text-cyan-700 underline">View game on TCGplayer</a>
                        </p>
                    }
                </article>
            }
        </div>
    }
    else if (Model.HasSearched)
    {
        <div class="rounded-xl border border-slate-300 bg-white/80 p-4 text-sm text-slate-600">No results found for this search.</div>
    }

    @if (Model.HasSearched && !string.IsNullOrWhiteSpace(Model.Endpoint) && (Model.HasPrevious || Model.HasMore))
    {
        <div class="mt-4 flex items-center justify-center gap-3">
            @if (Model.HasPrevious)
            {
                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Api" value="@Model.Api" />
                    <input type="hidden" name="Endpoint" value="@Model.Endpoint" />
                    <input type="hidden" name="CardQuery" value="@Model.CardQuery" />
                    <input type="hidden" name="CardNumber" value="@Model.CardNumber" />
                    <input type="hidden" name="CardPrinting" value="@Model.CardPrinting" />
                    <input type="hidden" name="CardCondition" value="@Model.CardCondition" />
                    <input type="hidden" name="CardOrderBy" value="@Model.CardOrderBy" />
                    <input type="hidden" name="CardOrder" value="@Model.CardOrder" />
                    <input type="hidden" name="PokemonSearch" value="@Model.PokemonSearch" />
                    <input type="hidden" name="PokemonTcgId" value="@Model.PokemonTcgId" />
                    <input type="hidden" name="PokemonSort" value="@Model.PokemonSort" />
                    <input type="hidden" name="EbaySearch" value="@Model.EbaySearch" />
                    <input type="hidden" name="EbayCategoryIds" value="@Model.EbayCategoryIds" />
                    <input type="hidden" name="EbayBuyingOptions" value="@Model.EbayBuyingOptions" />
                    <input type="hidden" name="EbaySort" value="@Model.EbaySort" />
                    <input type="hidden" name="SetGame" value="@Model.SetGame" />
                    <input type="hidden" name="SetQuery" value="@Model.SetQuery" />
                    <input type="hidden" name="SetOrderBy" value="@Model.SetOrderBy" />
                    <input type="hidden" name="SetOrder" value="@Model.SetOrder" />
                    <input type="hidden" name="Offset" value="@Model.PreviousOffset" />
                    <input type="hidden" name="Limit" value="@Model.Limit" />
                    <button type="submit" class="btn-ghost">Previous Page</button>
                </form>
            }

            <span class="text-sm font-semibold text-slate-700">Page @Model.CurrentPage of @Model.TotalPages</span>

            @if (Model.HasMore)
            {
                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Api" value="@Model.Api" />
                    <input type="hidden" name="Endpoint" value="@Model.Endpoint" />
                    <input type="hidden" name="CardQuery" value="@Model.CardQuery" />
                    <input type="hidden" name="CardNumber" value="@Model.CardNumber" />
                    <input type="hidden" name="CardPrinting" value="@Model.CardPrinting" />
                    <input type="hidden" name="CardCondition" value="@Model.CardCondition" />
                    <input type="hidden" name="CardOrderBy" value="@Model.CardOrderBy" />
                    <input type="hidden" name="CardOrder" value="@Model.CardOrder" />
                    <input type="hidden" name="PokemonSearch" value="@Model.PokemonSearch" />
                    <input type="hidden" name="PokemonTcgId" value="@Model.PokemonTcgId" />
                    <input type="hidden" name="PokemonSort" value="@Model.PokemonSort" />
                    <input type="hidden" name="EbaySearch" value="@Model.EbaySearch" />
                    <input type="hidden" name="EbayCategoryIds" value="@Model.EbayCategoryIds" />
                    <input type="hidden" name="EbayBuyingOptions" value="@Model.EbayBuyingOptions" />
                    <input type="hidden" name="EbaySort" value="@Model.EbaySort" />
                    <input type="hidden" name="SetGame" value="@Model.SetGame" />
                    <input type="hidden" name="SetQuery" value="@Model.SetQuery" />
                    <input type="hidden" name="SetOrderBy" value="@Model.SetOrderBy" />
                    <input type="hidden" name="SetOrder" value="@Model.SetOrder" />
                    <input type="hidden" name="Offset" value="@Model.NextOffset" />
                    <input type="hidden" name="Limit" value="@Model.Limit" />
                    <button type="submit" class="btn-primary">Next Page</button>
                </form>
            }
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const endpointSelect = document.getElementById("endpointSelect");
            const endpointField = document.getElementById("endpointField");
            const endpointLabel = document.getElementById("endpointLabel");
            const apiSelect = document.getElementById("apiSelect");
            const ebayCategoryIds = document.getElementById("ebayCategoryIds");
            const searchFieldGroups = Array.from(document.querySelectorAll("[data-search-fields]"));

            if (!apiSelect || !endpointSelect || !endpointField || !endpointLabel || !ebayCategoryIds) {
                return;
            }

            function supportedApis(option) {
                return (option.dataset.apis || "")
                    .split("|")
                    .map(function (api) { return api.trim(); })
                    .filter(Boolean);
            }

            function selectFirstVisibleEndpoint() {
                const firstVisibleOption = Array.from(endpointSelect.options).find(function (option) {
                    return !option.hidden;
                });

                endpointSelect.value = firstVisibleOption ? firstVisibleOption.value : "";
            }

            function syncFields() {
                const api = apiSelect.value || "";
                const selectedApiOption = apiSelect.options[apiSelect.selectedIndex];
                const defaultEndpoint = selectedApiOption ? selectedApiOption.dataset.defaultEndpoint || "" : "";
                const requiresEndpointSelection = !selectedApiOption || selectedApiOption.dataset.requiresEndpoint !== "false";

                endpointLabel.textContent = selectedApiOption ? selectedApiOption.dataset.endpointLabel || "Endpoint" : "Endpoint";
                endpointField.classList.toggle("hidden", !requiresEndpointSelection);

                endpointSelect.querySelectorAll("option").forEach(function (option) {
                    const apis = supportedApis(option);
                    option.hidden = apis.length > 0 && !apis.includes(api);
                });

                if (!requiresEndpointSelection) {
                    endpointSelect.value = defaultEndpoint;
                } else if (defaultEndpoint && !endpointSelect.value) {
                    endpointSelect.value = defaultEndpoint;
                }

                const selectedEndpointOption = endpointSelect.options[endpointSelect.selectedIndex];
                if (!selectedEndpointOption || selectedEndpointOption.hidden) {
                    selectFirstVisibleEndpoint();
                }

                const endpointOption = endpointSelect.options[endpointSelect.selectedIndex];
                ebayCategoryIds.value = endpointOption ? endpointOption.dataset.categoryIds || "" : "";

                const endpoint = (endpointSelect.value || defaultEndpoint || "").toLowerCase();
                searchFieldGroups.forEach(function (group) {
                    group.classList.toggle("hidden", group.dataset.api !== api || group.dataset.endpoint !== endpoint);
                });
            }

            apiSelect.addEventListener("change", syncFields);
            endpointSelect.addEventListener("change", syncFields);
            syncFields();

            document.querySelectorAll(".js-favorite-form").forEach(function (form) {
                form.addEventListener("submit", async function (event) {
                    event.preventDefault();

                    const button = form.querySelector(".js-favorite-btn");
                    if (!button || button.disabled) {
                        return;
                    }

                    const isFavorited = button.dataset.favorited === "true";
                    const removeUrl = form.dataset.removeUrl || "";
                    const tokenInput = form.querySelector("input[name='__RequestVerificationToken']");
                    const token = tokenInput ? tokenInput.value : "";
                    const addFormData = new URLSearchParams(new FormData(form));
                    const removeFormData = new URLSearchParams();
                    removeFormData.set("itemType", form.querySelector("input[name='ItemType']").value);
                    removeFormData.set("itemId", form.querySelector("input[name='ItemId']").value);
                    const targetUrl = isFavorited ? removeUrl : form.action;
                    const payload = isFavorited ? removeFormData.toString() : addFormData.toString();

                    button.disabled = true;

                    try {
                        const response = await fetch(targetUrl, {
                            method: "POST",
                            headers: {
                                "X-Requested-With": "XMLHttpRequest",
                                "RequestVerificationToken": token,
                                "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8"
                            },
                            body: payload
                        });

                        if (!response.ok) {
                            button.disabled = false;
                            return;
                        }

                        const result = await response.json();
                        if (!result || result.success !== true) {
                            button.disabled = false;
                            return;
                        }

                        if (isFavorited) {
                            button.dataset.favorited = "false";
                            button.classList.remove("bg-rose-50", "text-rose-700", "border", "border-rose-300");
                            button.setAttribute("aria-label", "Add to favorites");
                            button.title = "Add to favorites";
                        } else {
                            button.dataset.favorited = "true";
                            button.classList.add("bg-rose-50", "text-rose-700", "border", "border-rose-300");
                            button.setAttribute("aria-label", "Remove from favorites");
                            button.title = "Remove from favorites";
                        }

                        button.disabled = false;
                    } catch {
                        button.disabled = false;
                    }
                });
            });
        })();
    </script>
}
