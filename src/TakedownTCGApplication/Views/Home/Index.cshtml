@model HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="space-y-6">
    <div class="rounded-3xl border border-slate-300 bg-white/80 p-6 text-center shadow-sm md:p-10">
        <h1 class="text-3xl font-black tracking-tight text-slate-900 md:text-5xl">Welcome to TakedownTCG</h1>
        <p class="mt-3 text-sm text-slate-600 md:text-base">Search cards, sets, and games, then save favorites to your account.</p>
    </div>

    <div class="rounded-3xl border border-slate-300 bg-white/80 p-4 shadow-sm md:p-5">
        <div class="flex flex-col text-center">
            <h2 class="text-xl font-extrabold text-slate-900 md:text-2xl">Recently Completed Card Sales</h2>
            <p class="text-xs text-slate-600">Sold and completed eBay TCG card listings from SerpApi.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.CompletedSalesErrorMessage))
        {
            <div class="mt-4 rounded-xl border border-amber-300 bg-amber-50 p-3 text-sm text-amber-800">@Model.CompletedSalesErrorMessage</div>
        }
        else if (Model.CompletedSales.Count > 0)
        {
            <div id="completedSalesCarousel" class="completed-sales-carousel mt-3" data-count="@Model.CompletedSales.Count">
                <div class="completed-sales-stage" aria-live="polite">
                @for (int i = 0; i < Model.CompletedSales.Count; i++)
                {
                    var sale = Model.CompletedSales[i];
                    <article class="completed-sale-card"
                             data-carousel-index="@i">
                            <a href="@sale.Url" target="_blank" rel="noopener noreferrer" class="block">
                                <div class="completed-sale-image-frame">
                                    <img src="@sale.ImageUrl" alt="@sale.Title" class="completed-sale-image" loading="lazy" onerror="this.onerror=null;this.src='@sale.FallbackImageUrl';" />
                                </div>
                                <div class="completed-sale-body">
                                    <h3 class="completed-sale-title">@sale.Title</h3>
                                    <p class="completed-sale-price">@sale.PriceText</p>
                                    @if (!string.IsNullOrWhiteSpace(sale.Condition))
                                    {
                                        <p class="completed-sale-meta">@sale.Condition</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(sale.Seller))
                                    {
                                        <p class="completed-sale-meta completed-sale-seller">Seller: @sale.Seller</p>
                                    }
                                </div>
                            </a>
                        </article>
                }
                </div>
            </div>
        }
        else
        {
            <div class="mt-4 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-slate-600">
                No completed card sales found right now.
            </div>
        }
    </div>

    <div class="hidden rounded-3xl border border-slate-300 bg-white/80 p-8 shadow-sm md:block">
        <h3 class="text-center text-3xl font-extrabold text-slate-900">Ready to Search Products?</h3>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            <a asp-controller="Search" asp-action="Index" class="btn-primary">Search Products</a>
        </div>
    </div>

    <div class="space-y-3 md:hidden">
        <div class="rounded-2xl border border-slate-300 bg-white/90 p-4 shadow-sm">
            <h3 class="text-lg font-bold text-slate-900">Mobile Search Deck</h3>
            <p class="mt-1 text-sm text-slate-600">Fast, touch-friendly actions built for smaller screens.</p>
        </div>
        <div class="grid grid-cols-1 gap-3">
            <a asp-controller="Search" asp-action="Index" class="mobile-action">Search Products</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const carousel = document.getElementById("completedSalesCarousel");
            if (!carousel) {
                return;
            }

            const cards = Array.from(carousel.querySelectorAll(".completed-sale-card"));
            if (cards.length === 0) {
                return;
            }

            let activeIndex = 0;

            function setSlot(card, slot) {
                card.dataset.slot = slot;
                card.setAttribute("aria-hidden", slot === "off-left" || slot === "off-right" ? "true" : "false");
            }

            function render() {
                cards.forEach(function (card) {
                    setSlot(card, "off-left");
                });

                const leftIndex = (activeIndex - 1 + cards.length) % cards.length;
                const rightIndex = (activeIndex + 1) % cards.length;

                if (cards.length === 1) {
                    setSlot(cards[activeIndex], "center");
                    return;
                }

                if (cards.length === 2) {
                    setSlot(cards[activeIndex], "center");
                    setSlot(cards[rightIndex], "right");
                    return;
                }

                setSlot(cards[leftIndex], "left");
                setSlot(cards[activeIndex], "center");
                setSlot(cards[rightIndex], "right");

                cards.forEach(function (card, index) {
                    if (index !== leftIndex && index !== activeIndex && index !== rightIndex) {
                        const distanceToRight = (index - rightIndex + cards.length) % cards.length;
                        setSlot(card, distanceToRight < cards.length / 2 ? "off-right" : "off-left");
                    }
                });
            }

            render();
            window.setInterval(function () {
                activeIndex = (activeIndex - 1 + cards.length) % cards.length;
                render();
            }, 4500);
        })();
    </script>
}
