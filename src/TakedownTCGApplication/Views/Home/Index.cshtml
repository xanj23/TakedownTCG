@model HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="space-y-6">
    <div class="rounded-3xl border border-slate-300 bg-white/80 p-6 text-center shadow-sm md:p-10">
        <h1 class="text-3xl font-black tracking-tight text-slate-900 md:text-5xl">Welcome to TakedownTCG</h1>
        <p class="mt-3 text-sm text-slate-600 md:text-base">Search cards, sets, and games, then save favorites to your account.</p>
    </div>

    <div class="rounded-3xl border border-slate-300 bg-white/80 p-6 shadow-sm md:p-8">
        <div class="flex flex-col gap-1 text-center">
            <h2 class="text-2xl font-extrabold text-slate-900 md:text-3xl">Recently Completed Card Sales</h2>
            <p class="text-sm text-slate-600">Sold and completed eBay TCG card listings from SerpApi.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.CompletedSalesErrorMessage))
        {
            <div class="mt-4 rounded-xl border border-amber-300 bg-amber-50 p-3 text-sm text-amber-800">@Model.CompletedSalesErrorMessage</div>
        }
        else if (Model.CompletedSales.Count > 0)
        {
            <div id="completedSalesCarousel" class="mt-6 overflow-hidden" data-count="@Model.CompletedSales.Count">
                <div class="flex min-h-[25rem] items-center justify-center gap-3 md:gap-5">
                @for (int i = 0; i < Model.CompletedSales.Count; i++)
                {
                    var sale = Model.CompletedSales[i];
                    <article class="completed-sale-card hidden w-[28%] min-w-0 rounded-2xl border border-slate-300 bg-white shadow-sm transition-all duration-700 ease-out"
                             data-carousel-index="@i">
                            <a href="@sale.Url" target="_blank" rel="noopener noreferrer" class="block">
                                <img src="@sale.ImageUrl" alt="@sale.Title" class="h-40 w-full rounded-t-2xl bg-slate-50 object-contain p-3 md:h-48" loading="lazy" onerror="this.onerror=null;this.src='@sale.FallbackImageUrl';" />
                                <div class="space-y-2 p-4">
                                    <h3 class="line-clamp-2 text-sm font-bold text-slate-900">@sale.Title</h3>
                                    <p class="text-base font-extrabold text-cyan-700">@sale.PriceText</p>
                                    @if (!string.IsNullOrWhiteSpace(sale.Condition))
                                    {
                                        <p class="text-xs text-slate-600">@sale.Condition</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(sale.Seller))
                                    {
                                        <p class="text-xs text-slate-500">Seller: @sale.Seller</p>
                                    }
                                </div>
                            </a>
                        </article>
                }
                </div>
            </div>
        }
        else
        {
            <div class="mt-4 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-slate-600">
                No completed card sales found right now.
            </div>
        }
    </div>

    <div class="hidden rounded-3xl border border-slate-300 bg-white/80 p-8 shadow-sm md:block">
        <h3 class="text-center text-3xl font-extrabold text-slate-900">Ready to Search Products?</h3>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            <a asp-controller="Search" asp-action="Index" class="btn-primary">Search Products</a>
        </div>
    </div>

    <div class="space-y-3 md:hidden">
        <div class="rounded-2xl border border-slate-300 bg-white/90 p-4 shadow-sm">
            <h3 class="text-lg font-bold text-slate-900">Mobile Search Deck</h3>
            <p class="mt-1 text-sm text-slate-600">Fast, touch-friendly actions built for smaller screens.</p>
        </div>
        <div class="grid grid-cols-1 gap-3">
            <a asp-controller="Search" asp-action="Index" class="mobile-action">Search Products</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const carousel = document.getElementById("completedSalesCarousel");
            if (!carousel) {
                return;
            }

            const cards = Array.from(carousel.querySelectorAll(".completed-sale-card"));
            if (cards.length === 0) {
                return;
            }

            let activeIndex = Math.min(1, cards.length - 1);

            function resetCard(card) {
                card.classList.add("hidden");
                card.classList.remove("block", "scale-110", "scale-90", "opacity-100", "opacity-70", "z-10", "z-0", "w-[38%]", "w-[28%]");
            }

            function applyCard(card, position) {
                card.classList.remove("hidden");
                card.classList.add("block");

                if (position === "center") {
                    card.classList.add("scale-110", "opacity-100", "z-10", "w-[38%]");
                    return;
                }

                card.classList.add("scale-90", "opacity-70", "z-0", "w-[28%]");
            }

            function render() {
                cards.forEach(resetCard);

                const leftIndex = (activeIndex - 1 + cards.length) % cards.length;
                const rightIndex = (activeIndex + 1) % cards.length;

                if (cards.length === 1) {
                    applyCard(cards[activeIndex], "center");
                    return;
                }

                if (cards.length === 2) {
                    applyCard(cards[activeIndex], "center");
                    applyCard(cards[rightIndex], "side");
                    return;
                }

                applyCard(cards[leftIndex], "side");
                applyCard(cards[activeIndex], "center");
                applyCard(cards[rightIndex], "side");
            }

            render();
            window.setInterval(function () {
                activeIndex = (activeIndex + 1) % cards.length;
                render();
            }, 4500);
        })();
    </script>
}
